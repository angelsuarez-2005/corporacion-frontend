pipeline {
  agent any
  stages {
    stage('Inicio') {
      steps {
        echo 'Hola desde Jenkins en Windows'
      }
    }
    stage('Construcción') {
      steps {
        echo 'Simulando construcción...'
      }
    }
    stage('Pruebas') {
      steps {
        echo 'Ejecutando pruebas...'
      }
    }
    stage('Finalización') {
      steps {
        echo 'Pipeline finalizado'
      }
    }
  }
}
